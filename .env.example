# Environment Configuration Template for Tatvix AI Client Discovery System
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to version control

# =============================================================================
# GENERAL CONFIGURATION
# =============================================================================

# Environment: development, staging, production
TATVIX_ENVIRONMENT=development

# Debug mode (true/false)
TATVIX_GENERAL_DEBUG=false

# Logging configuration
TATVIX_GENERAL_LOG_LEVEL=INFO
TATVIX_LOGGING_FORMAT=json
TATVIX_LOGGING_DIRECTORY=logs

# =============================================================================
# LEAD GENERATION CONFIGURATION
# =============================================================================

# Default lead configuration
TATVIX_LEADS_DEFAULT_COUNTRY=US
TATVIX_LEADS_DEFAULT_INDUSTRY=IoT/Hardware
TATVIX_LEADS_DEFAULT_SCORE=8
TATVIX_LEADS_DEFAULT_SOURCE=Web Search

# =============================================================================
# API CREDENTIALS
# =============================================================================

# Groq AI API Key (required for AI analysis)
# Get from: https://console.groq.com/
TATVIX_API_GROQ_API_KEY=your_groq_api_key_here

# Groq Model Configuration
# Primary models for different analysis tasks
TATVIX_API_CLASSIFICATION_MODEL=llama-3.1-70b-versatile
TATVIX_API_ANALYSIS_MODEL=llama-3.1-70b-versatile
TATVIX_API_SCORING_MODEL=llama-3.1-70b-versatile

# AI Analysis Parameters
TATVIX_API_TEMPERATURE=0.1
TATVIX_API_MAX_TOKENS=4000
TATVIX_API_TIMEOUT=30

# OpenAI API Key (optional, for fallback AI analysis)
# Get from: https://platform.openai.com/api-keys
TATVIX_API_OPENAI_API_KEY=your_openai_api_key_here

# =============================================================================
# GOOGLE SERVICES
# =============================================================================

# Google Sheets API Credentials
# Path to your Google service account JSON file
TATVIX_GOOGLE_SHEETS_CREDENTIALS_PATH=path/to/your/service_account.json

# Google Sheets ID for storing leads
TATVIX_GOOGLE_SHEETS_ID=your_google_sheets_id_here

# Google Sheets worksheet name (default: 'Leads')
TATVIX_GOOGLE_WORKSHEET_NAME=Leads

# Google Sheets batch processing settings
TATVIX_GOOGLE_BATCH_SIZE=100
TATVIX_GOOGLE_SHEETS_TIMEOUT=30
TATVIX_GOOGLE_RETRY_ATTEMPTS=3

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================

# SMTP Configuration for sending emails
TATVIX_EMAIL_SMTP_SERVER=smtp.gmail.com
TATVIX_EMAIL_SMTP_PORT=587
TATVIX_EMAIL_SMTP_USERNAME=your_email@gmail.com
TATVIX_EMAIL_SMTP_PASSWORD=your_app_password_here

# Email settings
TATVIX_EMAIL_FROM_NAME=Tatvix Technologies
TATVIX_EMAIL_FROM_ADDRESS=your_email@gmail.com
TATVIX_EMAIL_REPLY_TO=your_email@gmail.com

# =============================================================================
# SEARCH CONFIGURATION
# =============================================================================

# Search engine settings
TATVIX_SEARCH_RESULTS_LIMIT=50
TATVIX_SEARCH_CONCURRENT_SEARCHES=5
TATVIX_SEARCH_QUERY_TIMEOUT=15

# Geographic targeting (comma-separated)
TATVIX_SEARCH_TARGET_COUNTRIES=Germany,USA,Netherlands,Sweden,India,UK,Canada

# =============================================================================
# WEB SCRAPING CONFIGURATION
# =============================================================================

# Scraping settings
TATVIX_SCRAPING_TIMEOUT=30
TATVIX_SCRAPING_MAX_PAGE_SIZE=10485760
# Inter-request delay bounds (seconds); spec targets 2 to 5
TATVIX_SCRAPING_DELAY_MIN=2.0
TATVIX_SCRAPING_DELAY_MAX=5.0
# Feature flag and Playwright pool
TATVIX_SCRAPING_ENABLED=true
TATVIX_SCRAPING_MAX_RETRIES=3
TATVIX_SCRAPING_RETRY_BACKOFF_BASE=2.0
TATVIX_SCRAPING_MAX_CONCURRENT=3
TATVIX_SCRAPING_PLAYWRIGHT_HEADLESS=true
# Comma-separated proxy URLs (optional), e.g. http://user:pass@host:8080,http://host2:8080
# TATVIX_SCRAPING_PROXY_URLS=

# User agents for scraping
TATVIX_SCRAPING_USER_AGENT_DESKTOP=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/91.0.4472.124 Safari/537.36
TATVIX_SCRAPING_USER_AGENT_MOBILE=Mozilla/5.0 (iPhone; CPU iPhone OS 14_6 like Mac OS X) AppleWebKit/605.1.15 (KHTML, like Gecko) Version/14.0 Mobile/15E148 Safari/604.1

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Vector database settings
TATVIX_DATABASE_SIMILARITY_THRESHOLD=0.85
TATVIX_DATABASE_DUPLICATE_THRESHOLD=0.90
TATVIX_DATABASE_BATCH_SIZE=100

# AI Analysis Cache Settings
TATVIX_DATABASE_CACHE_TTL_HOURS=24

# =============================================================================
# CHROMA VECTOR DATABASE CONFIGURATION
# =============================================================================

# Chroma database storage path (persistent storage directory)
TATVIX_CHROMA_PERSIST_DIRECTORY=./data/chroma_db

# Collection name for company embeddings
TATVIX_CHROMA_COLLECTION_NAME=company_embeddings

# Embedding model configuration
TATVIX_CHROMA_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
TATVIX_CHROMA_EMBEDDING_DIMENSION=384
TATVIX_CHROMA_DISTANCE_FUNCTION=cosine

# Performance settings
TATVIX_CHROMA_BATCH_SIZE=32
TATVIX_CHROMA_MAX_BATCH_SIZE=128
TATVIX_CHROMA_SEARCH_TIMEOUT_SECONDS=30
TATVIX_CHROMA_EMBEDDING_TIMEOUT_SECONDS=60

# Backup configuration
TATVIX_CHROMA_BACKUP_ENABLED=true
TATVIX_CHROMA_BACKUP_INTERVAL_HOURS=24
TATVIX_CHROMA_BACKUP_RETENTION_DAYS=30

# =============================================================================
# PROXY CONFIGURATION (Optional)
# =============================================================================

# Proxy settings for web scraping (optional)
# TATVIX_PROXY_HTTP=http://proxy.example.com:8080
# TATVIX_PROXY_HTTPS=https://proxy.example.com:8080
# TATVIX_PROXY_USERNAME=proxy_username
# TATVIX_PROXY_PASSWORD=proxy_password

# =============================================================================
# RATE LIMITING
# =============================================================================

# API rate limiting settings
TATVIX_GENERAL_API_TIMEOUT=30
TATVIX_GENERAL_MAX_RETRIES=3
TATVIX_GENERAL_RETRY_BACKOFF_FACTOR=2.0

# Request delays
TATVIX_SCRAPING_REQUEST_DELAY_MIN=1.0
TATVIX_SCRAPING_REQUEST_DELAY_MAX=5.0

# =============================================================================
# PERFORMANCE CONFIGURATION
# =============================================================================

# Memory and CPU limits
TATVIX_PERFORMANCE_MEMORY_LIMIT_MB=512
TATVIX_PERFORMANCE_CPU_CORES_LIMIT=4
TATVIX_PERFORMANCE_PROCESSING_TIMEOUT_HOURS=4

# Concurrent processing limits
TATVIX_PERFORMANCE_MAX_CONCURRENT_SEARCHES=5
TATVIX_PERFORMANCE_MAX_CONCURRENT_SCRAPES=3

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# Security settings
TATVIX_SECURITY_VALIDATE_SSL=true
TATVIX_SECURITY_ALLOW_REDIRECTS=true
TATVIX_SECURITY_MAX_REDIRECTS=5

# =============================================================================
# MONITORING AND ALERTING (Optional)
# =============================================================================

# Slack webhook for alerts (optional)
# TATVIX_ALERTS_SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# Email alerts (optional)
# TATVIX_ALERTS_EMAIL_ENABLED=false
# TATVIX_ALERTS_EMAIL_RECIPIENTS=admin@tatvixtech.com

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================

# Development-specific settings (only used in development environment)
TATVIX_DEV_MOCK_APIS=false
TATVIX_DEV_SAVE_RAW_DATA=true
TATVIX_DEV_SKIP_EMAIL_SENDING=true
TATVIX_DEV_USE_SAMPLE_DATA=false

# =============================================================================
# MULTI-SOURCE DISCOVERY CONFIGURATION
# =============================================================================

# Discovery engine settings
TATVIX_DISCOVERY_MAX_CONCURRENT_SOURCES=4
TATVIX_DISCOVERY_TIMEOUT_SECONDS=7200
TATVIX_DISCOVERY_DUPLICATE_THRESHOLD=0.9
TATVIX_DISCOVERY_MIN_CONFIDENCE_LEVEL=low
TATVIX_DISCOVERY_MIN_RELEVANCE_SCORE=0.3

# Default search parameters
TATVIX_DISCOVERY_DEFAULT_KEYWORDS=IoT,embedded systems,smart devices,industrial IoT,connected devices,sensor networks,edge computing
TATVIX_DISCOVERY_DEFAULT_CATEGORIES=hardware,iot,embedded,smart-home,industrial
TATVIX_DISCOVERY_DEFAULT_JOB_KEYWORDS=embedded software engineer,firmware engineer,IoT developer,hardware engineer,embedded systems engineer

# =============================================================================
# GITHUB INTEGRATION
# =============================================================================

# GitHub API Configuration
TATVIX_GITHUB_ENABLED=true
TATVIX_GITHUB_API_TOKEN=your_github_personal_access_token_here
TATVIX_GITHUB_TIMEOUT=30
TATVIX_GITHUB_MAX_RETRIES=3
TATVIX_GITHUB_MAX_RESULTS_PER_QUERY=100
TATVIX_GITHUB_MIN_STARS=5
TATVIX_GITHUB_MIN_FORKS=2

# =============================================================================
# STARTUP DIRECTORY INTEGRATIONS
# =============================================================================

# Product Hunt API
TATVIX_PRODUCT_HUNT_ENABLED=true
TATVIX_PRODUCT_HUNT_API_TOKEN=your_product_hunt_api_token_here
TATVIX_PRODUCT_HUNT_TIMEOUT=30
TATVIX_PRODUCT_HUNT_MAX_RETRIES=3

# Crunchbase API
TATVIX_CRUNCHBASE_ENABLED=true
TATVIX_CRUNCHBASE_API_KEY=your_crunchbase_api_key_here
TATVIX_CRUNCHBASE_TIMEOUT=30
TATVIX_CRUNCHBASE_MAX_RETRIES=3

# F6S (Search-based discovery)
TATVIX_F6S_ENABLED=true
TATVIX_F6S_TIMEOUT=30
TATVIX_F6S_MAX_RETRIES=3

# Gust (Search-based discovery)
TATVIX_GUST_ENABLED=true
TATVIX_GUST_TIMEOUT=30
TATVIX_GUST_MAX_RETRIES=3

# AngelList/Wellfound (Search-based discovery)
TATVIX_ANGELLIST_ENABLED=true
TATVIX_ANGELLIST_TIMEOUT=30
TATVIX_ANGELLIST_MAX_RETRIES=3

# Startup directories batch settings
TATVIX_STARTUP_DIRECTORIES_TIMEOUT=1800
TATVIX_STARTUP_DIRECTORIES_MAX_RETRIES=3

# =============================================================================
# PATENT DATABASE INTEGRATIONS
# =============================================================================

# USPTO Patents
TATVIX_USPTO_ENABLED=true
TATVIX_USPTO_TIMEOUT=30
TATVIX_USPTO_MAX_RETRIES=3

# Google Patents (Search-based discovery)
TATVIX_GOOGLE_PATENTS_ENABLED=true
TATVIX_GOOGLE_PATENTS_TIMEOUT=30
TATVIX_GOOGLE_PATENTS_MAX_RETRIES=3

# Patent mining batch settings
TATVIX_PATENTS_TIMEOUT=1800
TATVIX_PATENTS_MAX_RETRIES=3

# =============================================================================
# JOB BOARD INTEGRATIONS
# =============================================================================

# LinkedIn Jobs (Search-based discovery)
TATVIX_LINKEDIN_JOBS_ENABLED=true
TATVIX_LINKEDIN_JOBS_TIMEOUT=30
TATVIX_LINKEDIN_JOBS_MAX_RETRIES=3

# Indeed (Search-based discovery)
TATVIX_INDEED_ENABLED=true
TATVIX_INDEED_TIMEOUT=30
TATVIX_INDEED_MAX_RETRIES=3

# Glassdoor (Search-based discovery)
TATVIX_GLASSDOOR_ENABLED=true
TATVIX_GLASSDOOR_TIMEOUT=30
TATVIX_GLASSDOOR_MAX_RETRIES=3

# Job boards batch settings
TATVIX_JOB_BOARDS_TIMEOUT=1800
TATVIX_JOB_BOARDS_MAX_RETRIES=3

# =============================================================================
# EMAIL DISCOVERY & VERIFICATION CONFIGURATION
# =============================================================================

# Email Discovery Settings
# Maximum number of pages to crawl per domain for email discovery
TATVIX_EMAIL_MAX_PAGES_PER_DOMAIN=5

# Maximum crawl depth for multi-page email discovery
TATVIX_EMAIL_MAX_CRAWL_DEPTH=2

# Timeout for email extraction process (seconds)
TATVIX_EMAIL_EXTRACTION_TIMEOUT=30

# Email Verification Settings
# Timeout for email verification operations (seconds)
TATVIX_EMAIL_VERIFICATION_TIMEOUT=10

# Enable SMTP verification (WARNING: Use with caution to avoid being blocked)
# Set to false for DNS-only verification (recommended for most use cases)
TATVIX_EMAIL_SMTP_VERIFICATION_ENABLED=false

# Rate limit for email verification requests (requests per minute)
TATVIX_EMAIL_VERIFICATION_RATE_LIMIT=60

# Maximum email address length (RFC 5322 compliant)
TATVIX_EMAIL_MAX_LENGTH=254

# Quality Assessment Settings
# Minimum quality score threshold for email candidates (0.0 to 1.0)
TATVIX_EMAIL_MIN_QUALITY_THRESHOLD=0.5

# Enable disposable domain filtering
TATVIX_EMAIL_FILTER_DISPOSABLE_DOMAINS=true

# Enable role-based email detection and filtering
TATVIX_EMAIL_DETECT_ROLE_BASED=true

# Compliance and Ethics Settings
# Enable GDPR compliance checking
TATVIX_EMAIL_GDPR_COMPLIANCE_CHECK=true

# Enable CAN-SPAM compliance checking
TATVIX_EMAIL_CAN_SPAM_COMPLIANCE_CHECK=true

# Log level for email operations (DEBUG, INFO, WARNING, ERROR)
TATVIX_EMAIL_LOG_LEVEL=INFO

# Verification API Keys (Optional - Free Tiers Only)
# Note: These are optional and only for enhanced verification capabilities
# Leave empty to use built-in DNS-based verification only

# Hunter.io API key (free tier: 25 requests/month)
# TATVIX_EMAIL_HUNTER_API_KEY=

# ZeroBounce API key (free tier: 100 credits)
# TATVIX_EMAIL_ZEROBOUNCE_API_KEY=

# NeverBounce API key (free tier: 1000 credits)
# TATVIX_EMAIL_NEVERBOUNCE_API_KEY=

# =============================================================================
# DUPLICATE DETECTION CONFIGURATION
# =============================================================================

# Duplicate detection system settings
TATVIX_DUPLICATE_DETECTION_ENABLED=true

# Similarity thresholds (0.0 to 1.0)
TATVIX_DUPLICATE_DETECTION_SIMILARITY_THRESHOLD=0.90
TATVIX_DUPLICATE_DETECTION_EMBEDDING_SIMILARITY_THRESHOLD=0.85
TATVIX_DUPLICATE_DETECTION_BUSINESS_LOGIC_THRESHOLD=0.80
TATVIX_DUPLICATE_DETECTION_FUZZY_NAME_THRESHOLD=0.85
TATVIX_DUPLICATE_DETECTION_LOCATION_SIMILARITY_THRESHOLD=0.75
TATVIX_DUPLICATE_DETECTION_PHONE_SIMILARITY_THRESHOLD=0.90
TATVIX_DUPLICATE_DETECTION_TECHNOLOGY_OVERLAP_THRESHOLD=0.60

# Domain matching settings
TATVIX_DUPLICATE_DETECTION_DOMAIN_EXACT_MATCH=true

# Performance and batch settings
TATVIX_DUPLICATE_DETECTION_MAX_SIMILAR_COMPANIES=10
TATVIX_DUPLICATE_DETECTION_BATCH_SIZE=50
TATVIX_DUPLICATE_DETECTION_MAX_CONCURRENT_CHECKS=5
TATVIX_DUPLICATE_DETECTION_TIMEOUT_SECONDS=300
TATVIX_DUPLICATE_DETECTION_PERFORMANCE_TARGET_MS=100

# Caching settings
TATVIX_DUPLICATE_DETECTION_CACHE_ENABLED=true
TATVIX_DUPLICATE_DETECTION_CACHE_TTL_HOURS=24

# Audit and logging settings
TATVIX_DUPLICATE_DETECTION_AUDIT_ENABLED=true
TATVIX_DUPLICATE_DETECTION_LOG_SIMILARITY_SCORES=false

# Vector store settings
TATVIX_DUPLICATE_DETECTION_EMBEDDING_DIMENSION=384
TATVIX_DUPLICATE_DETECTION_VECTOR_STORE_TYPE=inmemory

# Similarity weights (must sum to 1.0)
TATVIX_DUPLICATE_DETECTION_NAME_SIMILARITY_WEIGHT=0.30
TATVIX_DUPLICATE_DETECTION_DESCRIPTION_SIMILARITY_WEIGHT=0.25
TATVIX_DUPLICATE_DETECTION_LOCATION_SIMILARITY_WEIGHT=0.15
TATVIX_DUPLICATE_DETECTION_PHONE_SIMILARITY_WEIGHT=0.10
TATVIX_DUPLICATE_DETECTION_TECHNOLOGY_SIMILARITY_WEIGHT=0.20

# =============================================================================
# BACKUP CONFIGURATION
# =============================================================================

# Backup settings
TATVIX_BACKUP_ENABLED=true
TATVIX_BACKUP_DIRECTORY=./backups
TATVIX_BACKUP_RETENTION_DAYS=30
TATVIX_BACKUP_SCHEDULE=daily