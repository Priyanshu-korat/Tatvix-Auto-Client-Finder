Google_sheet_json/
*credentials*.json
*service_account*.json
*.pem
*.p12

# Runtime / local data (embeddings, backups, caches)
data/
backups/

# Logs and Cache
logs/
cache/
*.log

# Temporary Files
*.tmp
*.temp
*.bak
*.backup

# Pickled caches and local binary state
*.pkl

